{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "devsplit",
  "version": "0.1.0",
  "identifier": "dev.devsplit.app",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "devsplit",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm", "dmg", "nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"],
    "category": "DeveloperTool",
    "shortDescription": "Split de trafego local de dev por path-prefix"
  },
  "plugins": {}
}
